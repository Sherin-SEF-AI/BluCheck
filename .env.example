# BluCheck environment template.
# Copy to .env for local development. In AWS, DATABASE_URL and JWT_SECRET are
# resolved from Secrets Manager (see backend/app/config.py) and these are ignored.

# ----- Shared AWS -----
AWS_REGION=ap-south-1
RESOURCE_PREFIX=blucheck

# ----- Backend API -----
# Local dev database URL. In AWS this comes from Secrets Manager (BLUCHECK_DB_SECRET_ARN).
DATABASE_URL=postgresql+psycopg://blucheck:blucheck@localhost:5432/blucheck
# Local dev JWT signing key. In AWS this comes from Secrets Manager (BLUCHECK_JWT_SECRET_ARN).
JWT_SECRET=dev-only-change-me
JWT_ALG=HS256
JWT_TTL_MINUTES=720

# S3 + SQS wiring (Terraform outputs feed these in AWS).
MEDIA_BUCKET=blucheck-media-REPLACE
DASHBOARD_BUCKET=blucheck-dashboard-REPLACE
EXTRACTION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/REPLACE/blucheck-extraction
KMS_KEY_ID=

# Secrets Manager ARNs (set in the ECS task definition; leave blank for local dev).
BLUCHECK_DB_SECRET_ARN=
BLUCHECK_JWT_SECRET_ARN=

# Presigned URL TTLs (seconds).
UPLOAD_URL_TTL=3600
FRAME_URL_TTL=300

# CORS origin for the dashboard (CloudFront URL in AWS).
DASHBOARD_ORIGIN=http://localhost:3000

# ----- Frame worker -----
FRAME_FPS=2
THUMB_WIDTH=480
SQS_WAIT_SECONDS=20
SQS_VISIBILITY_TIMEOUT=300
MAX_MESSAGE_RETRIES=5

# ----- Retention (days), also enforced by S3 lifecycle in Terraform -----
RAW_RETENTION_DAYS=90
FRAME_RETENTION_DAYS=365

# ----- Mobile / Dashboard -----
# Base URL of the API (ALB DNS or custom domain).
API_BASE_URL=http://localhost:8000
